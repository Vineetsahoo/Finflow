# Supabase PostgreSQL Configuration
SUPABASE_DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Redis Configuration (local Docker container)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Local Storage Path
STORAGE_PATH=/app/storage

# Service URLs
KYC_SERVICE_URL=http://localhost:8001
CREDIT_SERVICE_URL=http://localhost:8002
UPI_SERVICE_URL=http://localhost:8003
